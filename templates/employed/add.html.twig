{% extends 'base-auth.html.twig' %}

{% block title %}Ajouter un Employé{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- header -->
    <h1 class="mt-4">{{ block('title') }}</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
    <!-- fin header -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            {{ block('title') }}
        </div>
        <form method="post" class="needs-validation form-signin" novalidate>
            <div class="card-body">
                {% if error %}
                <div class="alert alert-danger" role="alert">
                    {{ error }}
                </div>
                {% endif %}

                {% if success %}
                <div class="alert alert-success" role="alert">
                    {{ success }}
                </div>
                {% endif %}

                <div class="mb-3">
                    <label for="fname" class="form-label">Prénom</label>
                    <input type="text" id="fname" name="fname" required class="form-control"
                        placeholder="Entrez le prénom">
                    <div class="invalid-feedback">
                        Veuillez entrer un prénom valide.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="lname" class="form-label">Nom</label>
                    <input type="text" id="lname" name="lname" required class="form-control"
                        placeholder="Entrez le nom">
                    <div class="invalid-feedback">
                        Veuillez entrer un nom valide.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="role" class="form-label">Rôle</label>
                    <select id="role" name="role" required class="form-select">
                        <option value="" selected disabled>Sélectionner un rôle</option>
                        <option value="Développeur">Développeur</option>
                        <option value="Designer">Designer</option>
                        <option value="Manager">Manager</option>
                        <option value="Commercial">Commercial</option>
                        <option value="Support">Support</option>
                        <option value="Autre">Autre</option>
                    </select>
                    <div class="invalid-feedback">
                        Veuillez sélectionner un rôle.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="phone" class="form-label">Téléphone</label>
                    <input type="tel" id="phone" name="phone" required class="form-control"
                        placeholder="Entrez le numéro de téléphone">
                    <div class="invalid-feedback">
                        Veuillez entrer un numéro de téléphone valide.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" id="email" name="email" required class="form-control"
                        placeholder="Entrez l'email">
                    <div class="invalid-feedback">
                        Veuillez entrer une adresse email valide.
                    </div>
                </div>

                <div class="card-footer d-flex align-items-center justify-content-center">
                    <button type="submit" class="btn btn-success mt-3 w-50">
                        Ajouter l'employé
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}