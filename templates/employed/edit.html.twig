{% extends 'base-auth.html.twig' %}

{% block title %}Modifier l'employé{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- header -->
    <h1 class="mt-4">{{ block('title') }}</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">{{ block('title') }} : {{ employed.getFullName() }}</li>
    </ol>
    <!-- fin header -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            {{ block('title') }}
        </div>
        {{ form_start(form, { attr: { class: 'needs-validation' } }) }}
        <div class="card-body">
            {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
            {% endfor %}

            <div class="mb-3">
                {{ form_label(form.fname, 'Nom') }}
                {{ form_widget(form.fname, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.fname) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.lname, 'Prénom') }}
                {{ form_widget(form.lname, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.lname) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.email, 'Email') }}
                {{ form_widget(form.email, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.phone, 'Téléphone') }}
                {{ form_widget(form.phone, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.phone) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.role, 'Rôle') }}
                {{ form_widget(form.role, { attr: { class: 'form-select' } }) }}
                {{ form_errors(form.role) }}
            </div>

            <div class="card-footer d-flex align-items-center justify-content-center gap-2">
                <button type="submit" class="btn btn-success">Enregistrer</button>
                <a href="{{ path('employed_view', { id: employed.id }) }}" class="btn btn-secondary">Annuler</a>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}