{% extends 'base-auth.html.twig' %}

{% block title %}Ajouter un projet{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- header -->
    <h1 class="mt-4">{{ block('title') }}</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
    <!-- fin header -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            {{ block('title') }}
        </div>
        <form method="post" class="needs-validation form-signin" novalidate>
            <div class="card-body">
                {% if error %}
                <div class="alert alert-danger" role="alert">
                    {{ error }}
                </div>
                {% endif %}

                {% if success %}
                <div class="alert alert-success" role="alert">
                    {{ success }}
                </div>
                {% endif %}

                <div class="mb-3">
                    <label for="name" class="form-label">Nom du projet</label>
                    <input type="text" id="name" name="name" class="form-control" required
                        placeholder="Ex : Intranet RH">
                    <div class="invalid-feedback">Veuillez entrer un nom de projet.</div>
                </div>

                <div class="mb-3">
                    <label for="descriptions" class="form-label">Description</label>
                    <textarea id="descriptions" name="descriptions" class="form-control" required rows="4"
                        placeholder="Brève description du projet..."></textarea>
                    <div class="invalid-feedback">Veuillez ajouter une description.</div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="beginning" class="form-label">Début</label>
                        <input type="datetime-local" id="beginning" name="beginning" class="form-control" required>
                        <div class="invalid-feedback">Date de début requise.</div>
                    </div>

                    <div class="col-md-6">
                        <label for="end" class="form-label">Fin</label>
                        <input type="datetime-local" id="end" name="end" class="form-control" required>
                        <div class="invalid-feedback">Date de fin requise.</div>
                    </div>
                </div>

                <div class="mb-3 mt-3">
                    <label for="status" class="form-label">Statut</label>
                    <select id="status" name="status" class="form-select" required>
                        <option value="" disabled selected>-- Choisir --</option>
                        <option value="0">En cours</option>
                        <option value="1">Terminé</option>
                    </select>
                    <div class="invalid-feedback">Veuillez choisir un statut.</div>
                </div>

                <div class="mb-4">
                    <label for="idEmployed" class="form-label">Employé associé</label>
                    <select id="idEmployed" name="idEmployed" class="form-select select2" required>
                        <option value="" disabled selected>-- Sélectionner un employé --</option>
                        {% for employe in employes %}
                        <option value="{{ employe.id }}">{{ employe.fname }} {{ employe.lname }}</option>
                        {% endfor %}
                    </select>
                    <div class="invalid-feedback">Veuillez sélectionner un employé.</div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary mt-3 w-100">Enregistrer</button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}