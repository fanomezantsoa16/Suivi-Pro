{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div id="layoutAuthentication_content">
    <main>
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-5">
                    <div class="card shadow-lg border-0 rounded-lg mt-5">
                        <div class="card-header">
                            <h3 class="text-center font-weight-light my-4">{{ block('title') }}</h3>
                        </div>
                        <div class="card-body">
                            {% if error %}
                            <div
                                style="color: red; background: #ffe6e6; padding: 10px; margin: 10px 0; border: 1px solid red;">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                            {% endif %}
                            <form method="post" class="needs-validation" novalidate>
                                <div class="form-floating mb-3">
                                    <input type="email" class="form-control" id="username" name="_username"
                                        value="{{ last_username }}" placeholder="name@example.com" required>
                                    <label for="username">Email:</label>
                                    <div class="invalid-feedback">Ce champ est requis.</div>
                                </div>
                                <div class="form-floating mb-3">
                                    <input type="password" class="form-control" type="password" id="password"
                                        name="_password" placeholder="Password" required>
                                    <label for="password">Mot de passe</label>
                                    <div class="invalid-feedback">Ce champ est requis.</div>
                                </div>

                                <div class="d-flex align-items-center justify-content-center mt-4 mb-0">
                                    <button type="submit" class="btn btn-primary w-50 py-2">
                                        Se connecter
                                    </button>
                                </div>
                            </form>
                        </div>
                        <div class="card-footer text-center py-3">
                            <p class="small">Pas encore de compte ?<a href="{{ path('signup') }}"> S'inscrire</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}