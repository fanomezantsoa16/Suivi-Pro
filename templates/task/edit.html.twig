{% extends 'base-auth.html.twig' %}

{% block title %}Modifier la tâche{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <!-- header -->
    <h1 class="mt-4">{{ block('title') }}</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">{{ block('title') }} : "{{ task.name }}</li>
    </ol>
    <!-- fin header -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-table me-1"></i>
            {{ block('title') }}
        </div>
        {{ form_start(form, { attr: { class: 'needs-validation' } }) }}
        <div class="card-body">
            {% if error %}
            <div class="alert alert-danger" role="alert">
                {{ error }}
            </div>
            {% endif %}

            {% if success %}
            <div class="alert alert-success" role="alert">
                {{ success }}
            </div>
            {% endif %}

            <div class="mb-3">
                {{ form_label(form.name, 'Nom du tache') }}
                {{ form_widget(form.name, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.description, 'Description du tache') }}
                {{ form_widget(form.description, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.startDate, 'Date de debut') }}
                {{ form_widget(form.startDate, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.startDate) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.endDate, 'Date de fin') }}
                {{ form_widget(form.endDate, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.endDate) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.status, 'status') }}
                {{ form_widget(form.status, { attr: { class: 'form-select' } }) }}
                {{ form_errors(form.status) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.project, 'Projet') }}
                {{ form_widget(form.project, { attr: { class: 'form-select select2' } }) }}
                {{ form_errors(form.project) }}
            </div>

            <div class="card-footer d-flex align-items-center justify-content-center gap-2">
                <button type="submit" class="btn btn-success">Enregistrer</button>
                <a href="{{ path('task_view', { id: task.id }) }}" class="btn btn-secondary">Annuler</a>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}