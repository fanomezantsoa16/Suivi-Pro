{% extends 'base-auth.html.twig' %}

{% block title %}Tache{% endblock %}

{% block body %}
<div class="container-fluid px-4">

    <!-- header -->
    <h1 class="mt-4">{{ block('title') }}</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">{{ block('title') }}</li>
    </ol>
    <!-- fin header -->
    <div class="card small">

        <div class="card-body">
            <table class="table table-striped table-hover align-middle">
                <tr>
                    <th>Nom du tâche</th>
                    <td>{{ task.name }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ task.description }}</td>
                </tr>
                <tr>
                    <th>Atribuée au projet</th>
                    <td>{{ task.project.name }}</td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td>{{ task.status }}</td>
                </tr>
                <tr>
                    <th>Date de Debut</th>
                    <td>{{ task.startDate|date('d/m/Y H:i') }}</td>
                </tr>
                <tr>
                    <th>Date de Fin</th>
                    <td>{{ task.endDate|date('d/m/Y H:i') }}</td>
                </tr>
                <tr>
                    <th>Date de création</th>
                    <td>{{ task.createdAt|date('d/m/Y H:i') }}</td>
                </tr>
                <tr>
                    <th>Dernière mise à jour</th>
                    <td>{{ task.updatedAt|date('d/m/Y H:i') }}</td>
                </tr>
                <tr>
                    <th>Distribués par</th>
                    <td>{{ user.username }} {{ user.email }}</td>
                </tr>

            </table>
        </div>

        <div class="card-footer">
            <div class="mt-4 d-flex align-items-center justify-content-center gap-2">
                <a href="{{ path('task_edit', { id: task.id }) }}" class="btn btn-primary">Modifier</a>

                <form method="post" action="{{ path('task_delete', { id: task.id }) }}" style="display:inline-block;"
                    onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet tâche ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.id) }}">
                    <button class="btn btn-danger">Supprimer</button>
                </form>
            </div>
        </div>

    </div>
</div>
{% endblock %}